# =============================================================================
# rag_pipeline — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# ---- Google AI (for embeddings) -----------------------------------------
GOOGLE_API_KEY=your-google-ai-studio-api-key
# Service account JSON (single-line) for Google Drive access
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project"}

# ---- Chat Database (Supabase) — RAG storage -----------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_KEY=your-service-role-key

# ---- Auth Database (PostgreSQL, read-only) -------------------------------
AUTH_DB_HOST=db.your-project.supabase.co
AUTH_DB_PORT=6543
AUTH_DB_NAME=postgres
AUTH_DB_USER=your-readonly-user
AUTH_DB_PASSWORD=your-readonly-password

# ---- GitHub ingestion (optional) ----------------------------------------
GITHUB_TOKEN=ghp_your-github-token
GITHUB_REPO=owner/repo

# ---- Google Drive ingestion (optional) ----------------------------------
# Comma-separated folder IDs to ingest
GOOGLE_DRIVE_FOLDER_IDS=your-folder-id-1,your-folder-id-2

# ---- Telegram ingestion (optional) --------------------------------------
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your-telegram-api-hash

# ---- Debug --------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=false
