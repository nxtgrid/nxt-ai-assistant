# =============================================================================
# chat_orchestrator — Environment Variables
# Copy this file to .env and fill in your values.
#
# Feature flags & tunable settings (toggles, model knobs, layout params, MCP
# server enables) are catalogued in shared/config/flags.env.example, generated
# from the single source of truth in shared/config/flag_registry.py.
# =============================================================================

# ---- Gemini / Google AI -------------------------------------------------
GOOGLE_API_KEY=your-google-ai-studio-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite   # Model used when primary hits rate limits
GEMINI_AGENT_PRO_MODEL=gemini-2.5-pro         # Model for complex agent tasks (analysis, multi-step reasoning)
GEMINI_DEEP_THINKING_MODEL=gemini-pro-latest  # Model for document editing / deep analysis (no thinking budget cap)
GEMINI_TEMPERATURE=                           # Leave blank to use model default (recommended for Gemini 2.5+)
GEMINI_MAX_OUTPUT_TOKENS=8192
GEMINI_LITE_MAX_OUTPUT_TOKENS=4096            # Token cap for verification / lightweight calls
GEMINI_THINKING_BUDGET=4096                   # Thinking token budget: -1=dynamic, 0=off, N=cap
GEMINI_HTTP_TIMEOUT=120                       # Per-request timeout in seconds
GOOGLE_SEARCH_GROUNDING=true                  # Enable Google Search grounding for staff users

# ---- Google Docs (system instructions) ----------------------------------
# Service account JSON (single-line) from Google Cloud Console
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project"}
# Google Doc IDs — from the URL: /document/d/<DOC_ID>/edit
CUSTOMER_SUPPORT_DOC_ID=your-google-doc-id-here
STAFF_SUPPORT_DOC_ID=your-google-doc-id-here
EXPERT_INSTRUCTIONS_DOC_ID=your-google-doc-id-here
TROUBLESHOOTING_PROCEDURES_DOC_ID=your-google-doc-id-here  # Shared procedures doc (customer + staff)
VERIFICATION_DOC_ID=your-google-doc-id-here

# ---- Chat Database (Supabase) -------------------------------------------
CHAT_DB_URL=https://your-project.supabase.co
CHAT_DB_SERVICE_KEY=your-service-role-key
# Direct Postgres URL — required for LangGraph agent checkpointer
CHAT_DB_POSTGRES_URL=postgresql://your-db-user:your-db-password@db.your-project.supabase.co:5432/postgres  # pragma: allowlist secret
# Legacy aliases (still used by some components)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# ---- Auth Database (PostgreSQL, read-only) -------------------------------
AUTH_DB_DIRECT_CONNECTION=true
AUTH_DB_HOST=db.your-project.supabase.co
AUTH_DB_PORT=6543
AUTH_DB_NAME=postgres
AUTH_DB_USER=your-readonly-user
AUTH_DB_PASSWORD=your-readonly-password
AUTH_DB_SSL_MODE=require

# ---- Telegram -----------------------------------------------------------
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_USERNAME=your_bot_username
# Chat ID of the escalation group (negative number for groups)
ESCALATION_TELEGRAM_CHAT_ID=-100123456789
# Comma-separated chat IDs that should never receive bot replies (e.g. log channels)
NO_REPLY_CHAT_IDS=

# ---- App security -------------------------------------------------------
# Random secret used to authenticate webhook calls from Telegram
API_KEY=generate-a-random-secret-here
SESSION_ID_SECRET=generate-another-random-secret-here
# Your deployed app URL (used for CORS and links)
APP_URL=https://yourapp.example.com

# ---- Staff / org config -------------------------------------------------
# SECURITY: STAFF_ORG_ID must match the actual organization_id of your internal
# org in the accounts/organizations tables. Leaving it as 2 is ONLY safe if your
# staff org's database ID happens to be 2. Set this before going live.
STAFF_ORG_ID=2
# Column on grids table indicating operator-managed generation. Override only if
# your schema uses a different name (must be a valid SQL identifier).
MANAGED_GENERATION_COLUMN=is_generation_managed_by_nxt_grid
# Default timezone for scheduling and display — IANA format (e.g. America/New_York)
DEFAULT_TIMEZONE=UTC
# After-hours escalation timezone (defaults to DEFAULT_TIMEZONE when unset)
AFTER_HOURS_TIMEZONE=
# Hour (0-23) when after-hours period begins (default: 19)
AFTER_HOURS_START_HOUR=19

# ---- Feature flags ------------------------------------------------------
ALLOW_PARALLEL_CALLS=true
MAX_TOOL_ROUNDS=10
VERIFICATION_ENABLED=true
VERIFICATION_MODEL=gemini-2.5-flash-lite      # LLM-as-judge model for customer response verification
WORKFLOW_PARAMETER_CONFIRMATION=true
INLINE_BUTTONS_ENABLED=true
PROCEDURE_BUTTONS_ENABLED=true
BOT_ENABLED=true
PERSISTENT_AGENTS_ENABLED=true               # Enable user-created persistent monitoring agents
STARTUP_RECOVERY_ENABLED=true                # Recover orphaned agent packets on service startup
MINI_APP_FORMS_ENABLED=false                 # Enable Telegram Mini App forms (requires mini app deployment)
DSPY_ENABLED=false                           # Enable DSPy program integration (experimental)
DSPY_PROGRAM_PATH=                           # Path to DSPy program definition file

# ---- Conversation tuning ------------------------------------------------
ACTIVE_THREAD_WINDOW_MINUTES=30              # Minutes a thread is considered "active" for context
AWAITING_INPUT_TIMEOUT_MINUTES=60            # Minutes before a paused workflow times out
AGENT_MAX_ACTIONS_PER_WAKE=5                 # Max tool calls a persistent agent can make per wake cycle
AGENT_MAX_TOOL_ROUNDS=3                      # Max tool-call rounds per agent wake
CONTEXT_FILTER_ENABLED=true                  # Filter conversation history to relevant context
CONVERSATION_SUMMARY_ENABLED=false          # Summarize long conversations before sending to Gemini
THREAD_DISENTANGLEMENT_ENABLED=false         # Separate overlapping conversation threads
THREAD_CLASSIFIER_MODEL=                     # Model override for thread classification (blank = GEMINI_MODEL)
LOOP_DETECTION_ENABLED=true                  # Detect and break tool-call loops
LOOP_DETECTION_THRESHOLD=3                   # Consecutive identical tool calls before loop is detected
GTR_ANALYSIS_MAX_TURNS=20                    # Max conversation turns to include in GTR analysis
MULTI_SITE_MAX_CONCURRENCY=3                 # Max parallel site operations in multi-site commands

# ---- Jira integration (orchestrator webhook + escalation) ---------------
# Note: MCP tool calls use the same vars from mcp_servers. If running both
# services locally with separate .env files, set these in both.
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_USERNAME=your-email@example.com         # Atlassian account email (NOT JIRA_EMAIL — that is wrong)
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=OPS
JIRA_ISSUE_TYPE=Task
JIRA_ORGANIZATION_FIELD_ID=                  # Custom field ID for organization (e.g. customfield_10100)
JIRA_WEBHOOK_SECRET=                         # HMAC secret for incoming Jira webhooks (fail-closed if unset)
JIRA_SWEEP_ENABLED=true                      # Enable daily escalation sweep to sync Jira status

# ---- Grafana scheduled sync ---------------------------------------------
GRAFANA_SYNC_HOUR=2                          # Hour (UTC) to run nightly Grafana panel metadata sync
GRAFANA_ACTIONS_ENABLED=false                # Allow Grafana render calls from orchestrator

# ---- Expert workflows (Google Drive folder/file IDs) --------------------
LPP_TEMPLATE_ID=your-drive-file-id
LPP_OUTPUT_FOLDER_ID=your-drive-folder-id
QGIS_TEMPLATE_FILE_ID=your-drive-file-id

# ---- Apps Script integrations (optional) --------------------------------
# Two separate Apps Script web apps can be deployed from scripts/anansi_helper.gs:
#   DOC_TRACKER: Prepends sequential codes to new documents (e.g. "DOC-0042 - Title").
#   ANANSI_HELPER: Replaces placeholder images in Google Sheets with uploaded charts.
# To deploy: open scripts/anansi_helper.gs in Apps Script → Deploy → New deployment
# → Web app. Copy the deployment URL. Set an API key in Script Properties.
DOC_TRACKER_DEPLOYMENT_ID=                   # Apps Script web app deployment ID
DOC_TRACKER_API_KEY=                         # API key set in Script Properties
ANANSI_HELPER_DEPLOYMENT_ID=                 # Apps Script web app deployment ID (image replacer)
ANANSI_HELPER_API_KEY=                       # API key set in Script Properties

# ---- Grid design integration (optional) ---------------------------------
GRID_DESIGN_APP_ID=
GRID_DESIGN_APP_KEY=
GRID_DESIGN_ACTIONS_ENABLED=false

# ---- Layout engine tuning (optional — shared/layout) --------------------
LAYOUT_POLE_SPACING_M=45                     # Distance between poles along roads (metres)
LAYOUT_MAX_DROP_DISTANCE_M=40                # Max service drop cable length to a building (metres)
LAYOUT_TARGET_COVERAGE_PCT=90                # Target building coverage before stopping layout iterations

# ---- Mini App -----------------------------------------------------------
MINI_APP_BASE_URL=                           # Public URL of the mini app (e.g. https://yourapp.example.com/mini-app)

# ---- Metrics & observability --------------------------------------------
METRICS_ENABLED=false                        # Enable scheduled metrics collection
METRICS_SCHEDULE_HOUR=6                      # Hour (UTC) to run daily metrics
METRICS_TIMEZONE=UTC                         # Timezone for metrics scheduling

# ---- Langfuse LLM observability (optional) ------------------------------
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=                         # From Langfuse project settings
LANGFUSE_SECRET_KEY=                         # From Langfuse project settings
LANGFUSE_HOST=https://cloud.langfuse.com     # Override for self-hosted Langfuse

# ---- MCP tools bridge URL (if running mcp_servers as separate service) --
BRIDGE_URL=http://localhost:8080
TOOLS_SERVICE_URL=http://localhost:8080      # Alias for BRIDGE_URL used by user_permissions

# ---- Settlement / community detection (optional) ------------------------
# Location holding one or more country GeoPackages plus a manifest.json that
# describes them. The anchor's country is reverse-geocoded and matched against
# the manifest, so coverage can grow beyond Nigeria without code changes.
SETTLEMENT_DATA_DIR=                          # Dir (or s3:// prefix) with country GeoPackages + manifest.json
# Optional inline manifest (JSON string) — handy for container/S3 deploys where
# dropping a manifest.json file is awkward. Overrides {SETTLEMENT_DATA_DIR}/manifest.json.
SETTLEMENT_MANIFEST_JSON=
# Legacy single-file mode (Nigeria only) — still honoured if SETTLEMENT_DATA_DIR is unset.
GRID3_GPKG_PATH=                             # Absolute path to GRID3_NGA_settlement_extents.gpkg (3.4 GB)

# ---- Debug --------------------------------------------------------------
DEBUG=false
LOG_LEVEL=INFO

# --- Building footprint datasets (community-anchored LPP) ---
# Microsoft Global ML Building Footprints (ODbL) — Bing zoom-9 QuadKey tiles
MS_BUILDINGS_DATASET_LINKS_URL=https://minedbuildings.z5.web.core.windows.net/global-buildings/dataset-links.csv
# Google Open Buildings (CC BY-4.0 / ODbL) — S2 level-6 tiles, public GCS bucket
GOOGLE_OPEN_BUILDINGS_BASE_URL=https://storage.googleapis.com/open-buildings-data/v3/polygons_s2_level_6_gzip_no_header
GOOGLE_OPEN_BUILDINGS_MIN_CONFIDENCE=0.70
# Cross-check: pull Google when MS footprint count is below this fraction of the
# GRID3 block-attribute estimate for the boundary (0 disables the cross-check).
FOOTPRINT_CROSSCHECK_MIN_RATIO=0.80
