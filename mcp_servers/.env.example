# =============================================================================
# mcp_servers — Environment Variables
# Copy this file to .env and fill in your values.
#
# Feature flags & tunable settings (toggles, model knobs, layout params, MCP
# server enables) are catalogued in shared/config/flags.env.example, generated
# from the single source of truth in shared/config/flag_registry.py.
# =============================================================================

# ---- Auth Database (PostgreSQL, read-only) -------------------------------
AUTH_DB_DIRECT_CONNECTION=true
AUTH_DB_HOST=db.your-project.supabase.co
AUTH_DB_PORT=6543
AUTH_DB_NAME=postgres
AUTH_DB_USER=your-readonly-user
AUTH_DB_PASSWORD=your-readonly-password

# ---- Chat Database (Supabase) -------------------------------------------
CHAT_DB_URL=https://your-project.supabase.co
CHAT_DB_SERVICE_KEY=your-service-role-key
CHAT_DB_USER=                                # Direct Postgres user (optional, for write operations)
CHAT_DB_PASSWORD=                            # Direct Postgres password (optional)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# ---- TimescaleDB time-series database (optional) ------------------------
TIMESCALE_HOST=
TIMESCALE_PORT=5432
TIMESCALE_DATABASE=tsdb
TIMESCALE_USER=
TIMESCALE_PASSWORD=

# ---- JIRA integration (optional) ----------------------------------------
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_USERNAME=your-email@example.com         # Atlassian account email (used as API username)
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=OPS
JIRA_ISSUE_TYPE=Task
JIRA_ORGANIZATION_FIELD_ID=                  # Custom field ID for org (e.g. customfield_10100)
JIRA_OPS_CLOUD_ID=                           # Atlassian cloud ID for JSM Ops (from admin console)
JIRA_OPS_SCHEDULE_ID=                        # JSM on-call schedule ID

# ---- Victron VRM API (optional — for inverter/solar monitoring) ----------
VRM_TOKEN=your-vrm-api-token
VRM_MQTT_USER=your-vrm-email@example.com     # VRM account email (used as MQTT username)
VRM_MQTT_PASSWORD=Token your-vrm-personal-access-token  # VRM personal access token, formatted as "Token <token>"
VRM_USER_ID=                                 # VRM numeric user ID (from /users/me endpoint)
VRM_BATCH_MAX_CONCURRENT=5                   # Max concurrent VRM API requests for multi-site calls

# ---- Grafana (optional) -------------------------------------------------
GRAFANA_URL=http://localhost:3000
GRAFANA_USERNAME=admin
GRAFANA_PASSWORD=your-grafana-password
GRAFANA_ENABLED=false                        # Master switch for Grafana tool availability
GRAFANA_PANELS_METADATA=                     # JSON string of panel metadata (set by Grafana indexer script)
GRAFANA_ENABLED_PANELS=                      # Comma-separated panel names to expose as tools (blank = all indexed)
GRAFANA_DASHBOARD_VARIABLES=                 # JSON: dashboard UID → variable overrides for queries
GRAFANA_QUERY_TIMEOUT=30                     # Seconds to wait for panel data queries
GRAFANA_METADATA_TIMEOUT=10                  # Seconds to wait for dashboard metadata fetches
GRAFANA_VARIABLE_TIMEOUT=5                   # Seconds to wait for dashboard variable resolution

# ---- Grid management platform (optional) --------------------------------
# When set, tool responses include direct links to the grid management UI
PLATFORM_BASE_URL=https://yourapp.example.com

# ---- Mini App -----------------------------------------------------------
MINI_APP_BASE_URL=                           # Public URL of the mini app
MINI_APP_HMAC_SECRET=                        # HMAC secret for verifying mini app Telegram init data

# ---- Staff / org config -------------------------------------------------
# SECURITY: STAFF_ORG_ID must match the actual organization_id of your internal
# org in the accounts/organizations tables. Leaving it as 2 is ONLY safe if your
# staff org's database ID happens to be 2. Set this before going live.
STAFF_ORG_ID=2
# Column on grids table indicating operator-managed generation. Override only if
# your schema uses a different name (must be a valid SQL identifier).
MANAGED_GENERATION_COLUMN=is_generation_managed_by_nxt_grid
DEFAULT_TIMEZONE=UTC
ORGANIZATION_NAME=Your Organization          # Shown in chart watermarks and equipment error messages
DEFAULT_LOG_HOURS=24                         # Default time window for log queries (hours)

# ---- Server enable flags (set to true to activate) ----------------------
SUPABASE_ACTIONS_ENABLED=false
JIRA_ACTIONS_ENABLED=false
TIMESCALE_ACTIONS_ENABLED=false
VRM_ACTIONS_ENABLED=false
EQUIPMENT_CONTROL_ACTIONS_ENABLED=false
CALIN_ACTIONS_ENABLED=false
GRID_DESIGN_ACTIONS_ENABLED=false
META_ACTIONS_ENABLED=false                   # Enable meta/admin tools (restart, reload, etc.)
SOLAR_ACTIONS_ENABLED=false                  # Enable solar energy data tools
CUSTOMER_METER_ACTIONS_ENABLED=false         # Enable meter write actions (unassign, recommission, HPS limit, token resend)
CUSTOMER_METER_POWER_LIMIT_OPTIONS=200,600   # Comma-separated allowed HPS power limits in watts; first value is default

# ---- Tool-level disable (optional) --------------------------------------
MCP_DISABLED_TOOLS=[]                        # JSON array of "server:tool" strings to disable specific tools

# ---- Tiamat API (optional — external asset management) ------------------
TIAMAT_API_URL=                              # Base URL for Tiamat API (e.g. https://tiamat.example.com)
TIAMAT_API_KEY=                              # API key from api_keys table (X-API-KEY header)
TIAMAT_BEARER_TOKEN=                         # Bearer token (alternative auth to TIAMAT_API_KEY)

# ---- AppSheet (optional — grid design automation) -----------------------
GRID_DESIGN_APP_ID=
GRID_DESIGN_APP_KEY=
GRID_DESIGN_ACTIONS_TABLE=                   # AppSheet table name for actions
GRID_DESIGN_BOM_TABLE=                       # AppSheet table name for BOM
GRID_DESIGN_DESIGNS_TABLE=                   # AppSheet table name for designs
GRID_DESIGN_GRIDS_TABLE=                     # AppSheet table name for grids
GRID_DESIGN_BOM_WAIT=10                      # Seconds to wait for BOM generation
GRID_DESIGN_AUTOPOPULATE_WAIT=5              # Seconds to wait for autopopulate
APPSHEET_REGION=                             # AppSheet region override (e.g. eu)

# ---- Equipment diagnostics tuning (optional) ----------------------------
EQUIPMENT_DIAGNOSTICS_DEFAULT_TIME_RANGE=24  # Default hours of data to fetch for diagnostics
EQUIPMENT_DIAGNOSTICS_OUTAGE_THRESHOLD_W=50  # Power threshold (W) below which grid is considered off
EQUIPMENT_DIAGNOSTICS_CHART_WIDTH=1200       # Chart width in pixels
EQUIPMENT_DIAGNOSTICS_CHART_HEIGHT=600       # Chart height in pixels

# ---- Equipment control access (optional) --------------------------------
EQUIPMENT_CONTROL_ALLOWED_USERS=             # Comma-separated emails allowed to issue control commands

# ---- Calin meter API (optional) -----------------------------------------
CALIN_V1_BASE_URL=                           # Calin v1 API base URL
CALIN_V1_COMPANY=                            # Calin v1 company identifier
CALIN_V1_USERNAME=                           # Calin v1 API username
CALIN_V1_PASSWORD=                           # Calin v1 API password
CALIN_V2_BASE_URL=                           # Calin v2 API base URL
CALIN_V2_COMPANY=                            # Calin v2 company identifier
CALIN_V2_USERNAME=                           # Calin v2 API username
CALIN_V2_PASSWORD=                           # Calin v2 API password

# ---- Chirpstack LoRaWAN (optional) --------------------------------------
CHIRPSTACK_BASE_URL=                         # ChirpStack server URL (e.g. https://chirpstack.example.com)
CHIRPSTACK_API_KEY=                          # ChirpStack API key
CHIRPSTACK_TENANT_ID=                        # ChirpStack tenant UUID

# ---- Loki log aggregation (optional) ------------------------------------
LOKI_URL=                                    # Loki push/query URL (e.g. http://loki:3100)
LOKI_USERNAME=                               # Loki basic auth username (if auth enabled)
LOKI_PASSWORD=                               # Loki basic auth password (if auth enabled)

# ---- Payment processor (optional) ---------------------------------------
PAYMENT_PROCESSOR_API_URL=                   # Base URL for payment processor API
PAYMENT_PROCESSOR_SECRET_KEY=                # Payment processor secret key

# ---- Nigerian regulatory reference data (optional) ----------------------
NIGERIA_IMPORT_STANDARDS_PDF_ID=             # Google Drive file ID for import standards PDF
NIGERIA_IMPORT_TARIFF_SHEET_ID=              # Google Drive file ID for tariff spreadsheet

# ---- Tavily web search (optional) ---------------------------------------
TAVILY_API_KEY=                              # Tavily search API key (for web search tools)

# ---- Codebase search (optional) -----------------------------------------
CODEBASE_PATH=                               # Absolute path to codebase for code search tools
CODEBASE_VECTOR_DB_PATH=                     # Path to vector DB for semantic code search

# ---- Escalation (optional — needed if orchestrator not running locally) -
ESCALATION_TELEGRAM_CHAT_ID=                 # Telegram chat ID for escalation group
TELEGRAM_BOT_TOKEN=                          # Bot token (needed for progress message sends)
EXPERT_INSTRUCTIONS_DOC_ID=                  # Expert workflow definitions doc

# ---- CORS (comma-separated allowed origins) -----------------------------
CORS_ALLOWED_ORIGINS=http://localhost:8501

# ---- Debug --------------------------------------------------------------
DEBUG=false
LOG_LEVEL=INFO
DEVELOPMENT_MODE=false

# --- Building footprint datasets (community-anchored LPP) ---
# Microsoft Global ML Building Footprints (ODbL) — Bing zoom-9 QuadKey tiles
MS_BUILDINGS_DATASET_LINKS_URL=https://minedbuildings.z5.web.core.windows.net/global-buildings/dataset-links.csv
# Google Open Buildings (CC BY-4.0 / ODbL) — S2 level-6 tiles, public GCS bucket
GOOGLE_OPEN_BUILDINGS_BASE_URL=https://storage.googleapis.com/open-buildings-data/v3/polygons_s2_level_6_gzip_no_header
GOOGLE_OPEN_BUILDINGS_MIN_CONFIDENCE=0.70
# Cross-check: pull Google when MS footprint count is below this fraction of the
# GRID3 block-attribute estimate for the boundary (0 disables the cross-check).
FOOTPRINT_CROSSCHECK_MIN_RATIO=0.80
