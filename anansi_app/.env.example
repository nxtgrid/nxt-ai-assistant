# =============================================================================
# anansi_app — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# ---- Google OAuth (for admin UI login) ----------------------------------
# Create credentials at: https://console.cloud.google.com/apis/credentials
AUTH_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
AUTH_CLIENT_SECRET=your-oauth-client-secret
AUTH_REDIRECT_URI=http://localhost:8501/oauth2callback
AUTH_SERVER_METADATA_URL=https://accounts.google.com/.well-known/openid-configuration
AUTH_COOKIE_SECRET=generate-a-random-secret-here
# Aliases used by some auth components (same values as AUTH_CLIENT_*)
GOOGLE_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-oauth-client-secret

# ---- Google AI (for Grafana indexer scripts) ----------------------------
GOOGLE_API_KEY=your-google-ai-studio-api-key
GEMINI_MODEL=gemini-2.5-flash                # Model used by indexer for panel description generation

# ---- LLM provider settings shown in the Settings page -------------------
LLM_PROVIDER=gemini
OPENROUTER_API_KEY=
# OPEN_ROUTER_BEARER_TOKEN is also accepted as a local alias
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_PROVIDER_ORDER=google-vertex
OPENROUTER_ALLOW_FALLBACKS=false

# ---- Chat Database (Supabase) -------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# ---- Telegram -----------------------------------------------------------
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_USERNAME=your_bot_username

# ---- Admin access -------------------------------------------------------
# Comma-separated Google account emails allowed to access the admin UI.
# Grants the Bot Admin section AND view access to the Grid Design section.
ALLOWED_VIEWER_EMAILS=admin@example.com
# API key used to authenticate calls to the orchestrator (same value as orchestrator API_KEY)
API_KEY=your-orchestrator-api-key

# ---- Grid Design access control -----------------------------------------
# The Grid Design section is visible to the UNION of all four whitelists below
# (ALLOWED_VIEWER_EMAILS + the three here). A user in none of them is denied.
# Edit rights are strictly separated; everyone else sees grid tables read-only.
#
# View-only access to all grid tables (no edit):
GRID_DESIGN_ALLOWED_USERS=
# Can EDIT every grid table EXCEPT Purchases (BoS):
GRID_DESIGN_EDITORS=
# Can EDIT only the Purchases (BoS) table:
GRID_PROCUREMENT_EDITORS=
# Local-dev ONLY: set to 1 to bypass Google OAuth and grant all permissions.
# NEVER set this in production.
# GRID_DESIGN_DEV_NO_AUTH=0

# ---- Chat orchestrator connection ---------------------------------------
CHAT_ORCHESTRATOR_URL=http://localhost:8000/chat
ANANSI_BOT_HEALTH_URL=http://localhost:8000/health
MINI_APP_BASE_URL=http://localhost:8000/mini-app

# ---- DigitalOcean (for Settings page — controls live env vars) ----------
# Leave blank if not using DigitalOcean App Platform
DIGITALOCEAN_APP_ID=
DIGITALOCEAN_API_TOKEN=

# ---- Grafana (for settings management and indexer) ----------------------
GRAFANA_URL=http://localhost:3000
GRAFANA_USERNAME=admin
GRAFANA_PASSWORD=your-grafana-password
GRAFANA_FOLDER_NAME=                         # Grafana folder to restrict panel discovery (empty = all folders)
# Set by the indexer scripts — stored in DO env vars in production
GRAFANA_PANELS_METADATA=                     # JSON string of indexed panel metadata
GRAFANA_ENABLED_DASHBOARDS=                  # Comma-separated dashboard UIDs to expose as tools
GRAFANA_FORCE_FULL_REINDEX=false             # Force full re-index even if metadata exists

# ---- Staff / access control ---------------------------------------------
STAFF_ORG_ID=2                               # organization_id that grants staff-mode access — review before deploy
DEFAULT_TIMEZONE=UTC                         # System-wide timezone default (IANA format, e.g. America/New_York)

# ---- After-hours escalation (optional) ----------------------------------
AFTER_HOURS_TIMEZONE=                        # Timezone for after-hours logic (defaults to DEFAULT_TIMEZONE)
AFTER_HOURS_START_HOUR=19                    # Hour (0-23) when after-hours period begins

# ---- LLM Observability (Langfuse — optional) ----------------------------
LANGFUSE_DASHBOARD_URL=                      # e.g. https://cloud.langfuse.com/project/<your-project-id>

# ---- Debug --------------------------------------------------------------
LOG_LEVEL=INFO
