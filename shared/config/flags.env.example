# ============================================================================
# Anansi feature flags & tunable settings
# AUTOGENERATED from shared/config/flag_registry.py — DO NOT EDIT BY HAND.
# Regenerate with:  python -m shared.config.flag_registry > shared/config/flags.env.example
#
# These are operator-tunable toggles and knobs only. Secrets and connection
# strings (API keys, AUTH_DB_*, CHAT_DB_*, tokens) live in each service's own
# .env.example and are never managed here.
# ============================================================================

# IANA timezone used as the fallback for display/scheduling when a grid has no timezone of its own (e.g. 'Africa/Lagos', 'UTC'). (read-only)
DEFAULT_TIMEZONE=UTC

# Organization id treated as internal staff (full tool access). (read-only)
STAFF_ORG_ID=2

# Backend for runtime settings management: 'auto' (DigitalOcean if DIGITALOCEAN_APP_ID + token are set, else env-file), 'digitalocean', or 'envfile'. (read-only)
SETTINGS_BACKEND=auto

# Path the env-file settings backend reads/writes when not on DigitalOcean. (read-only)
SETTINGS_FILE=.env.settings

# Allow Gemini to request parallel tool calls.
ALLOW_PARALLEL_CALLS=true

# Maximum sequential tool-call rounds per turn.
MAX_TOOL_ROUNDS=5

# Master switch for the Telegram bot.
BOT_ENABLED=true

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL).
LOG_LEVEL=INFO

# Generation provider: 'gemini' for direct Google Gemini or 'openrouter' for OpenRouter. [anansi-bot]
LLM_PROVIDER=gemini

# Primary generation model id for the selected provider.
GEMINI_MODEL=gemini-2.5-flash

# Fallback generation model id for the selected provider.
GEMINI_FALLBACK_MODEL=gemini-2.5-flash

# Lightweight model for structured natural-language expert routing.
INTENT_ROUTER_MODEL=gemini-2.5-flash-lite

# Generation temperature where supported by the selected model.
GEMINI_TEMPERATURE=0.2

# Max output tokens for the primary model. (read-only)
GEMINI_MAX_OUTPUT_TOKENS=8192

# Max output tokens for the lite/verification model. (read-only)
GEMINI_LITE_MAX_OUTPUT_TOKENS=1024

# Model for deep-thinking tasks (document editing, complex analysis). [anansi-bot]
GEMINI_DEEP_THINKING_MODEL=

# Optional comma-separated OpenRouter provider slugs to try first, e.g. 'google-vertex' for Google Vertex BYOK. [anansi-bot]
OPENROUTER_PROVIDER_ORDER=

# Allow OpenRouter to fall back to other endpoints when provider routing is configured. [anansi-bot]
OPENROUTER_ALLOW_FALLBACKS=true

# Require OpenRouter endpoints that support the requested parameters/tool schema. [anansi-bot]
OPENROUTER_REQUIRE_PARAMETERS=false

# Embedding model used for RAG ingestion/retrieval. (read-only)
EMBEDDING_MODEL=gemini-embedding-001

# Enable the equipment diagnostics MCP server (disabling hides all of its tools).
EQUIPMENT_DIAGNOSTICS_ENABLED=true

# Enable the vrm MCP server (disabling hides all of its tools).
VRM_ENABLED=true

# Enable the jira MCP server (disabling hides all of its tools).
JIRA_ENABLED=true

# Enable the meters MCP server (disabling hides all of its tools).
METERS_ENABLED=true

# Enable the equipment control MCP server (disabling hides all of its tools).
EQUIPMENT_CONTROL_ENABLED=true

# Enable the payment processor MCP server (disabling hides all of its tools).
PAYMENT_PROCESSOR_ENABLED=true

# Enable the customer MCP server (disabling hides all of its tools).
CUSTOMER_ENABLED=true

# Enable the grafana MCP server (disabling hides all of its tools).
GRAFANA_ENABLED=true

# Enable the schedule MCP server (disabling hides all of its tools).
SCHEDULE_ENABLED=true

# Enable the meta MCP server (disabling hides all of its tools).
META_ENABLED=true

# Enable the grid design MCP server (disabling hides all of its tools).
GRID_DESIGN_ENABLED=true

# Enable the solar MCP server (disabling hides all of its tools).
SOLAR_ENABLED=true

# Enable the knowledge MCP server (disabling hides all of its tools).
KNOWLEDGE_ENABLED=true

# Enable the messaging MCP server (disabling hides all of its tools).
MESSAGING_ENABLED=true

# Enable the reference MCP server (disabling hides all of its tools).
REFERENCE_ENABLED=true

# JSON array of "server:tool" strings to disable individual tools.
MCP_DISABLED_TOOLS=[]

# Enable retrieval-augmented generation.
rag__enabled=false

# Number of RAG chunks to retrieve per query.
rag__top_k=5

# Enable scheduled metrics collection.
METRICS_ENABLED=true

# Hour of day (0-23) to run metrics collection.
METRICS_SCHEDULE_HOUR=9

# Enable LLM-as-judge verification of outgoing customer messages. [anansi-bot]
VERIFICATION_ENABLED=false

# Google Doc id holding verification criteria. [anansi-bot]
VERIFICATION_DOC_ID=

# Model used for response verification. [anansi-bot]
VERIFICATION_MODEL=gemini-2.5-flash-lite

# Accept external notifications on POST /chat/notify and forward them to Telegram (n8n / VRM / Grafana passthrough). When off the endpoint returns 503. [anansi-bot]
NOTIFY_ENDPOINT_ENABLED=false

# Prompt the user to confirm editable workflow parameters. [anansi-bot]
WORKFLOW_PARAMETER_CONFIRMATION=true

# Telegram inline buttons for decision prompts. [anansi-bot]
INLINE_BUTTONS_ENABLED=false

# Procedure buttons in customer support chats. [anansi-bot]
PROCEDURE_BUTTONS_ENABLED=false

# Telegram WebApp popups for workflow parameters. [anansi-bot]
MINI_APP_FORMS_ENABLED=false

# Conversation context filtering. [anansi-bot]
CONTEXT_FILTER_ENABLED=false

# Multi-thread conversation disentanglement. [anansi-bot]
THREAD_DISENTANGLEMENT_ENABLED=false

# Window (minutes) a thread stays active. [anansi-bot]
ACTIVE_THREAD_WINDOW_MINUTES=60

# Rolling conversation summarization. [anansi-bot]
CONVERSATION_SUMMARY_ENABLED=false

# Enable user-created persistent monitoring agents. [anansi-bot]
PERSISTENT_AGENTS_ENABLED=false

# Timeout (minutes) for an expert awaiting user input. [anansi-bot]
AWAITING_INPUT_TIMEOUT_MINUTES=180

# Google Doc id holding expert/workflow definitions. [anansi-bot]
EXPERT_INSTRUCTIONS_DOC_ID=

# Enable Langfuse LLM observability tracing. [anansi-bot]
LANGFUSE_ENABLED=false

# Grafana base URL.
GRAFANA_URL=http://localhost:3000

# Grafana username.
GRAFANA_USERNAME=

# Grafana password. (secret)
GRAFANA_PASSWORD=

# Grafana folder to source dashboards from.
GRAFANA_FOLDER_NAME=

# Prompt used to auto-generate Grafana panel tool descriptions.
GRAFANA_PANEL_DESCRIPTION_PROMPT=You are a system that generates tool descriptions for Grafana dashboard panels. Given a panel with title, description, query, and dashboard variables, create a concise tool description that explains what data this panel shows and what variables it requires. Format: A tool description suitable for an LLM to understand when to use this panel.

# Comma-separated list of enabled Grafana panels.
GRAFANA_ENABLED_PANELS=

# Comma-separated list of enabled Grafana dashboards.
GRAFANA_ENABLED_DASHBOARDS=

# Hour of day (0-23) to sync Grafana panel metadata.
GRAFANA_SYNC_HOUR=2

# Force a full Grafana panel reindex on next sync.
GRAFANA_FORCE_FULL_REINDEX=false

# Comma-separated emails allowed to view the admin app.
ALLOWED_VIEWER_EMAILS=

# Comma-separated emails allowed to issue equipment-control commands. [anansi-bot]
EQUIPMENT_CONTROL_ALLOWED_USERS=

# Comma-separated emails with view-only access to the Grid Design tables.
GRID_DESIGN_ALLOWED_USERS=

# Comma-separated emails allowed to edit all Grid Design tables except Procurements.
GRID_DESIGN_EDITORS=

# Comma-separated emails allowed to edit only the Procurements (Purchases/BoS) table.
GRID_PROCUREMENT_EDITORS=

# Telegram chat id for the escalation group. (read-only)
ESCALATION_TELEGRAM_CHAT_ID=

# Telegram chat id for debug output. (read-only)
DEBUG_TELEGRAM_CHAT_ID=

# Google Doc id for customer-mode system instructions. (read-only)
CUSTOMER_SUPPORT_DOC_ID=

# Google Doc id for staff-mode system instructions. (read-only)
STAFF_SUPPORT_DOC_ID=

# Google Doc id for shared troubleshooting procedures. (read-only)
TROUBLESHOOTING_PROCEDURES_DOC_ID=

# Spacing between poles along roads (m). [anansi-bot]
LAYOUT_POLE_SPACING_M=45.0

# Max drop-cable length to a building (m). [anansi-bot]
LAYOUT_MAX_DROP_DISTANCE_M=40.0

# Target building coverage (%). [anansi-bot]
LAYOUT_TARGET_COVERAGE_PCT=90.0

# Roof area per kWp (m²/kWp). [anansi-bot]
LAYOUT_SQM_PER_KWP=15.5

# Estimated kWp per building. [anansi-bot]
LAYOUT_KWP_PER_BUILDING=0.25

# Minimum estimated site kWp. [anansi-bot]
LAYOUT_MIN_ESTIMATED_KWP=30.0

# Buffer around buildings (m). [anansi-bot]
LAYOUT_BUILDING_BUFFER_M=15.0

# Setback from site boundary (m). [anansi-bot]
LAYOUT_SITE_SETBACK_M=5.0

# Setback from roads (m). [anansi-bot]
LAYOUT_ROAD_SETBACK_M=5.0

# Corridor clearance (m). [anansi-bot]
LAYOUT_CORRIDOR_CLEARANCE_M=10.0

# Tree-canopy avoidance threshold (m). [anansi-bot]
LAYOUT_CANOPY_THRESHOLD_M=5.0

# Min separation between candidate sites (m). [anansi-bot]
LAYOUT_MIN_CANDIDATE_SEPARATION_M=100.0

# Max candidate sites to evaluate. [anansi-bot]
LAYOUT_MAX_CANDIDATES=3

# Distance under which poles are deduplicated (m). [anansi-bot]
LAYOUT_POLE_DEDUP_DISTANCE_M=5.0

# Node-snapping tolerance (m). [anansi-bot]
LAYOUT_SNAP_NODE_TOLERANCE_M=1.0

# Gap under which segments merge (m). [anansi-bot]
LAYOUT_MERGE_GAP_THRESHOLD_M=5.0

# Max gap for pole redistribution (m). [anansi-bot]
LAYOUT_REDISTRIBUTE_GAP_MAX_M=10.0

# Lightning-protection radius (m). [anansi-bot]
LAYOUT_LIGHTNING_RADIUS_M=13.5

# Google Slides template id for LPP output. [anansi-bot]
LPP_TEMPLATE_ID=

# QGIS template file id for site layouts. [anansi-bot]
QGIS_TEMPLATE_FILE_ID=

# Drive folder id for LPP output. [anansi-bot]
LPP_OUTPUT_FOLDER_ID=

# Sheet id for import tariff reference data. [anansi-bot]
NIGERIA_IMPORT_TARIFF_SHEET_ID=

# PDF id for import standards reference data. [anansi-bot]
NIGERIA_IMPORT_STANDARDS_PDF_ID=
