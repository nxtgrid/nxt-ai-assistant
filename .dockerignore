dev.sh
docker-compose*.yml
.pre-commit-config.yaml
.claude/
pyproject.toml
.secrets.baseline

# Large test output images (not app assets)
scripts/**/*.png
scripts/**/*.zip
**/*.jpg

# Environment/secrets
**/.env
**/.env.*
